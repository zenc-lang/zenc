
def ROWS = 3;
def COLS = 3;

struct Matrix {
    data: int[9];  // ROWS * COLS
}

impl Matrix {
    fn get(self, row: int, col: int) -> int {
        return self.data[row * COLS + col];
    }

    fn set(self, row: int, col: int, val: int) {
        self.data[row * COLS + col] = val;
    }

    static fn identity() -> Matrix {
        let m = Matrix{data: [1,0,0, 0,1,0, 0,0,1]};
        return m;
    }
}

struct Vec3 {
    data: int[3];
}

impl Vec3 {
    fn get(self, i: int) -> int {
        return self.data[i];
    }
}

test "single index via get" {
    let v = Vec3{data: [10, 20, 30]};
    assert(v[0] == 10, "Single index [0] failed");
    assert(v[1] == 20, "Single index [1] failed");
    assert(v[2] == 30, "Single index [2] failed");
}

test "multi index via get" {
    let m = Matrix::identity();

    // Diagonal should be 1
    assert(m[0, 0] == 1, "Matrix [0,0] failed");
    assert(m[1, 1] == 1, "Matrix [1,1] failed");
    assert(m[2, 2] == 1, "Matrix [2,2] failed");

    // Off-diagonal should be 0
    assert(m[0, 1] == 0, "Matrix [0,1] failed");
    assert(m[1, 0] == 0, "Matrix [1,0] failed");
    assert(m[0, 2] == 0, "Matrix [0,2] failed");
}

test "multi index expressions" {
    let m = Matrix{data: [1,2,3, 4,5,6, 7,8,9]};

    // Test with computed indices
    let row = 1;
    let col = 2;
    assert(m[row, col] == 6, "Matrix [1,2] failed");
    assert(m[0, col] == 3, "Matrix [0,2] failed");
    assert(m[row, 0] == 4, "Matrix [1,0] failed");
}

test "multi index with set" {
    let m = Matrix{data: [0,0,0, 0,0,0, 0,0,0]};
    m.set(1, 2, 42);
    assert(m[1, 2] == 42, "Matrix set then get failed");
}
