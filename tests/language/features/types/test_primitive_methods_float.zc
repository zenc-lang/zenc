
impl f64 {
    fn abs(self) -> f64 {
        return *self < 0.0 ? -(*self) : *self;
    }
}

impl int {
    fn plus_one(self) -> int {
        return *self + 1;
    }
}

test "f64_method_on_variable" {
    let x = -10.0;
    assert x.abs() == 10.0;
}

test "f64_method_on_parenthesized_literal" {
    assert ((-10.0).abs() == 10.0);
}

test "f64_method_on_literal" {
    assert 10.0.abs() == 10.0;
}

test "int_method_on_literal" {
    // Previously failed: lexer consumed 10.plus_one as a broken float token
    assert 10.plus_one() == 11;
}
